<?xml version="1.0" encoding="utf-8"?>
<!-- Variable font – single file covers wght 100–900 via fontVariationSettings -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font android:fontStyle="normal" android:fontWeight="400"
        android:font="@font/dm_sans_var"
        app:fontVariationSettings="'wght' 400" />
    <font android:fontStyle="normal" android:fontWeight="500"
        android:font="@font/dm_sans_var"
        app:fontVariationSettings="'wght' 500" />
    <font android:fontStyle="normal" android:fontWeight="600"
        android:font="@font/dm_sans_var"
        app:fontVariationSettings="'wght' 600" />
    <font android:fontStyle="normal" android:fontWeight="700"
        android:font="@font/dm_sans_var"
        app:fontVariationSettings="'wght' 700" />
</font-family>
