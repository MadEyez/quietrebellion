<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Status Card ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_searching"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/tvBattery"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                        <TextView
                            android:id="@+id/tvFirmware"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:textAppearance="?attr/textAppearanceBodySmall" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <!-- Now Playing -->
                    <TextView
                        android:id="@+id/tvNowPlaying"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorPrimary" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReconnect"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:layout_marginEnd="8dp"
                            android:maxLines="1"
                            android:text="@string/str_reconnect" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRename"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:layout_marginEnd="8dp"
                            android:maxLines="1"
                            android:text="@string/str_rename" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPowerOff"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:text="@string/str_power_off_btn" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Listening Mode Card ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_listening_mode"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <RadioGroup
                        android:id="@+id/rgModes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <!-- custom mode slots added programmatically -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Noise Control Card ────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_noise_control"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <!-- Manual ANC controls (hidden when Auto ANC is on) -->
                    <LinearLayout
                        android:id="@+id/layoutManualCnc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCncLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/str_noise_control"
                            android:textAppearance="@style/TextAppearance.QuietRebellion.MonoLabel"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <SeekBar
                            android:id="@+id/sbCnc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="10" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/str_anc_aware_label"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/str_anc_anc_label"
                                android:gravity="end"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Status shown instead of slider when Auto ANC is on -->
                    <TextView
                        android:id="@+id/tvAutoCncStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_auto_anc_status"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_anc"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_anc_desc"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swAutoCnc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_spatial_audio"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                    <RadioGroup
                        android:id="@+id/rgSpatial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <RadioButton android:id="@+id/rbSpatialOff"  android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_spatial_off" />
                        <RadioButton android:id="@+id/rbSpatialRoom" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_spatial_room" />
                        <RadioButton android:id="@+id/rbSpatialHead" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_spatial_head" />
                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/str_wind_block"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swWindBlock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Settings Card ─────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_settings"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />


                    <!-- Auto Play/Pause -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_play_pause"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_play_pause_desc"
                                android:textAppearance="?attr:textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swAutoPlayPause"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Auto Answer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_answer"
                                android:textAppearance="?attr:textAppearanceBodyMedium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_auto_answer_desc"
                                android:textAppearance="?attr:textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swAutoAnswer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Equalizer Card ────────────────────────────────────────── -->            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_equalizer"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <!--
                        Labels aligned to dot x-positions (1/6, 3/6, 5/6 of width).
                        Spacer scheme 1:2:2:1 → centers at ~17%, 50%, ~83%.
                    -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/str_eq_bass" android:textAppearance="?attr:textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView android:id="@+id/tvBassVal" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textAppearance="@style/TextAppearance.QuietRebellion.MonoValue"
                                android:textColor="?attr/colorPrimary" />
                        </LinearLayout>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="2"/>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/str_eq_mid" android:textAppearance="?attr:textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView android:id="@+id/tvMidVal" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textAppearance="@style/TextAppearance.QuietRebellion.MonoValue"
                                android:textColor="?attr/colorPrimary" />
                        </LinearLayout>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="2"/>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/str_eq_treble" android:textAppearance="?attr:textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                            <TextView android:id="@+id/tvTrebleVal" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0"
                                android:textAppearance="@style/TextAppearance.QuietRebellion.MonoValue"
                                android:textColor="?attr/colorPrimary" />
                        </LinearLayout>

                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Graphic EQ curve – dots sit at x = w*1/4, w*2/4, w*3/4 -->
                    <net.quietrebellion.EqCurveView
                        android:id="@+id/eqCurveView"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="12dp" />


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_sidetone"
                        android:textAppearance="?attr:textAppearanceBodyMedium" />
                    <RadioGroup
                        android:id="@+id/rgSidetone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbSidetoneOff"    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_sidetone_off" />
                        <RadioButton android:id="@+id/rbSidetoneHigh"   android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_sidetone_high" />
                        <RadioButton android:id="@+id/rbSidetoneMedium" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_sidetone_med" />
                        <RadioButton android:id="@+id/rbSidetoneLow"    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/str_sidetone_low" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Connection Card ───────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_connection"
                        android:textAppearance="?attr:textAppearanceLabelLarge"
                        android:textColor="?attr/colorPrimary"
                        android:textAllCaps="true"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/str_multipoint"
                            android:textAppearance="?attr:textAppearanceBodyMedium" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swMultipoint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Paired device list, shown only when multipoint is on + active source known -->
                    <TextView
                        android:id="@+id/tvPairedDevicesLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/str_switch_audio_source"
                        android:textAppearance="?attr:textAppearanceBodyMedium"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvActiveDevice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr:textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />
                    <TextView
                        android:id="@+id/tvPairedDevicesHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/str_multipoint_hint"
                        android:textAppearance="?attr:textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />
                    <RadioGroup
                        android:id="@+id/rgPairedDevices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <!-- Pairing Mode -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPairingMode"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/str_enter_pairing_mode_btn" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

